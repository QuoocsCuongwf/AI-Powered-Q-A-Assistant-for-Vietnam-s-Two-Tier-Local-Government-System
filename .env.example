# ==============================================================
# Environment Variables — copy to .env and fill in values
# ==============================================================

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/legal_chatbot

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── RAG Pipeline ──────────────────────────────────────────────
RAG_BACKEND=huggingface
RAG_MODEL=auto
RAG_MAX_TOKENS=1024
RAG_TEMPERATURE=0.1

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=30
