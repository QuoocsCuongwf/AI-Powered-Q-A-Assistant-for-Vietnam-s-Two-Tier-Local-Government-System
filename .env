# ==============================================================
# Environment Variables — copy to .env and fill in values
# ==============================================================

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legal_chatbot

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=30
